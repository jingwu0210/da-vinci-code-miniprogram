/**
 * 全局主题样式 —— 所有页面级 wxss 通过 @import 引用。
 * 值与 docs/DESIGN-SPEC.md §2 保持一致。
 */

page {
  /* === 暗色主题（毛毡）=== */
  --felt:              #2C3A4A;
  --black-tile:        #1A1A1E;
  --white-tile:        #EBEBE5;
  --text-on-black:     #EBEBE5;
  --text-on-white:     #1A1A1E;
  --text-primary:      #EBEBE5;
  --text-secondary:    #8A8A90;
  --divider:           #3E4A58;
  --panel-bg:          rgba(44,58,74,0.95);

  /* === 功能色 === */
  --correct:           #4A7C59;
  --error:             #8B4A4A;
  --gold:              #9E8C6C;

  /* === 字级 (rpx) === */
  --fs-title:     44rpx;
  --fs-subtitle:  36rpx;
  --fs-body:      28rpx;
  --fs-caption:   24rpx;
  --fs-tile-lg:   48rpx;     /* 大牌数字 */
  --fs-tile:      40rpx;     /* 标准牌数字 */
  --fs-tile-sm:   32rpx;     /* 小牌数字 */

  /* === 间距阶梯 (rpx) === */
  --sp-xs:   8rpx;
  --sp-sm:   16rpx;
  --sp-md:   24rpx;
  --sp-lg:   32rpx;
  --sp-xl:   48rpx;

  /* === 圆角 === */
  --radius-sm:  8rpx;
  --radius-md:  12rpx;
  --radius-lg:  16rpx;

  /* === 牌体 (1:2 竖立) === */
  --tile-ratio:      2;            /* 高/宽比，2 = 1:2 竖立 */
  --tile-radius:     4rpx;
  --tile-gap:        6rpx;
  --tile-thickness:  4rpx;         /* 3D 厚度偏移 */
  --tile-shadow:     rgba(0,0,0,0.4);
  --tile-highlight:  rgba(255,255,255,0.06);

  /* === 面板/卡片 === */
  --panel-bg:         rgba(235,235,229,0.06);
  --panel-border:     rgba(235,235,229,0.08);
  --insert-gold:      #9E8C6C;      /* 插入指示三角色 */

  /* === 基础样式 === */
  background-color: var(--felt);
  font-family: 'PingFang SC', -apple-system, sans-serif;
  font-size: var(--fs-body);
  color: var(--text-primary);
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  padding: var(--sp-md);
}

/* 通用按钮重置 */
button {
  background: initial;
  padding: 0;
  margin: 0;
}
button:focus { outline: 0; }
button::after { border: none; }
