/**
 * 全局主题样式 —— 所有页面级 wxss 通过 @import 引用。
 * 值与 docs/DESIGN-SPEC.md §0 保持一致（浅色主题）。
 */

page {
  /* === 配色（浅色主题） === */
  --bg-page:           #F3F4F6;
  --bg-card:           #FFFFFF;
  --bg-card-hover:     #F9FAFB;
  --text-primary:      #1F2937;
  --text-secondary:    #6B7280;
  --text-muted:        #9CA3AF;
  --divider:           #E5E7EB;
  --primary:           #1F2937;
  --primary-hover:     #374151;
  --primary-foreground:#FFFFFF;

  /* 次按钮 */
  --secondary-button:         #E5E7EB;
  --secondary-button-foreground: #1F2937;

  /* 按钮尺寸 */
  --btn-radius:        24rpx;
  --btn-height:        96rpx;
  --btn-font-size:     32rpx;

  /* 功能色 */
  --gold:              #C9A84C;
  --gold-muted:        #B8A282;
  --correct:           #10B981;
  --error:             #EF4444;

  /* 牌色（不变，牌面色独立于页面主题） */
  --black-tile:        #1E1E22;
  --white-tile:        #E6E6DE;
  --text-on-black:     #D8D4CC;
  --text-on-white:     #3A3834;

  /* === 字体 === */
  --font-title:   'PingFang SC', 'Helvetica Neue', sans-serif;
  --font-body:    'PingFang SC', -apple-system, sans-serif;
  --font-mono:    'SF Mono', 'Courier New', monospace;
  --font-number:  'Georgia', 'Times New Roman', serif;

  --fs-title:     40rpx;
  --fs-subtitle:  32rpx;
  --fs-body:      28rpx;
  --fs-caption:   22rpx;
  --fs-small:     20rpx;

  /* === 间距 === */
  --sp-xs:   8rpx;
  --sp-sm:   16rpx;
  --sp-md:   24rpx;
  --sp-lg:   32rpx;
  --sp-xl:   48rpx;

  /* === 圆角 === */
  --radius-sm:   8rpx;
  --radius-md:   12rpx;
  --radius-lg:   16rpx;

  /* === 阴影 === */
  --shadow-card:  0 2rpx 8rpx rgba(0,0,0,0.08);
  --shadow-btn:   0 2rpx 4rpx rgba(0,0,0,0.1);
  --shadow-modal: 0 8rpx 24rpx rgba(0,0,0,0.15);

  /* === 牌体 === */
  --tile-ratio:      2;
  --tile-radius:     6rpx;
  --tile-gap:        6rpx;

  /* === 基础 === */
  background-color: var(--bg-page);
  font-family: var(--font-body);
  font-size: var(--fs-body);
  color: var(--text-primary);
}

/* 通用按钮重置 */
button {
  background: initial;
  padding: 0;
  margin: 0;
  border-radius: var(--radius-md);
  font-size: var(--fs-body);
}
button:focus { outline: 0; }
button::after { border: none; }
