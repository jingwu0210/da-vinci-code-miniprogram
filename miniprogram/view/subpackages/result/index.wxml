<view class="page" style="height:{{pageHeight}}">
  <view class="loading-ctn" wx:if="{{loading}}">
    <text class="loading-text">结算中…</text>
  </view>

  <block wx:elif="{{record}}">
    <view class="result-header {{isWinner ? 'winner' : 'loser'}}">
      <text class="result-emoji">{{isWinner ? '🏆' : '💔'}}</text>
      <text class="result-title">{{isWinner ? '你赢了！' : '再接再厉'}}</text>
    </view>

    <view class="info-card">
      <view class="info-row">
        <text class="info-label">模式</text>
        <text class="info-value">{{record.mode === 'ai' ? '人机对战' : '好友联机'}}</text>
      </view>
      <view class="info-row" wx:if="{{record.difficulty}}">
        <text class="info-label">难度</text>
        <text class="info-value">{{record.diffStr}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">回合数</text>
        <text class="info-value">{{record.totalTurns}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">时长</text>
        <text class="info-value">{{record.durStr}}</text>
      </view>
    </view>

    <view class="players-card">
      <view class="section-title">排名</view>
      <view class="player-row" wx:for="{{record.players}}" wx:key="openid">
        <text class="player-rank">{{index === 0 ? '🥇' : index === 1 ? '🥈' : index === 2 ? '🥉' : '📋'}}</text>
        <text class="player-name {{item.isWinner ? 'winner-name' : ''}}">{{item.nickName}}{{item.isWinner ? ' (胜)' : ''}}</text>
        <text class="player-tiles">{{item.tilesRemaining === 0 ? '全部翻开' : '剩 ' + item.tilesRemaining + ' 张'}}</text>
      </view>
    </view>

    <view class="btn-group">
      <button class="btn btn-share" open-type="share">📤 分享战绩</button>
      <button class="btn btn-lobby" bindtap="onTapLobby">返回大厅</button>
    </view>
  </block>

  <view class="loading-ctn" wx:else>
    <text class="loading-text">加载失败</text>
    <button class="btn btn-lobby" bindtap="onTapLobby" style="margin-top:32rpx">返回大厅</button>
  </view>
</view>
