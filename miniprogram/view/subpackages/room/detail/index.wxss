/* 房间等待室 */
.room-page { background: var(--bg-page); min-height: 100vh; }
.main { padding: 0 32rpx 48rpx; }

/* 房间码深色条 */
.code-bar {
  margin: 24rpx 0;
  height: 88rpx; background: #1F2937; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32rpx;
}
.code-text { font-size: 30rpx; font-weight: 500; color: #FFFFFF; font-family: 'Courier New', monospace; letter-spacing: 4rpx; }
.code-actions { display: flex; align-items: center; }
.code-action {
  font-size: 28rpx; color: rgba(255,255,255,0.8); padding: 8rpx 16rpx;
  display: flex; flex-direction: row; align-items: center;
}
.code-action-icon { width: 32rpx; height: 32rpx; flex-shrink: 0; margin-right: 8rpx; }
.code-action-text { white-space: nowrap; font-size: 28rpx; color: rgba(255,255,255,0.8); }
.share-btn-inline {
  background: transparent; border: none; padding: 8rpx 16rpx; margin: 0;
  font-size: 28rpx; line-height: 1.2; color: rgba(255,255,255,0.8);
  display: flex; flex-direction: row; align-items: center;
}
.share-btn-inline .code-action-icon { margin-right: 8rpx; }
.share-btn-inline .code-action-text { white-space: nowrap; }
.share-btn-inline::after { border: none; }

.label { font-size: var(--fs-body); color: var(--text-secondary); margin: 24rpx 0 16rpx; display: block; }

/* 玩家卡片 */
.player-list { display: flex; flex-direction: column; gap: 12rpx; }
.player-card {
  background: var(--bg-card); border-radius: 24rpx; padding: 24rpx 28rpx;
  display: flex; align-items: center; gap: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.player-card.placeholder {
  border: 2rpx dashed #D1D5DB; background: transparent;
  box-shadow: none; justify-content: center;
}
.p-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  background: var(--divider); display: flex; align-items: center;
  justify-content: center; font-size: 36rpx; flex-shrink: 0;
  overflow: hidden;
}
.p-avatar-img { width: 100%; height: 100%; }
.p-avatar-placeholder { font-size: 36rpx; }
.p-avatar.empty { opacity: 0.4; }
.p-info { flex: 1; }
.p-name-row { display: flex; align-items: center; gap: 12rpx; }
.p-name { font-size: var(--fs-body); color: var(--text-primary); font-weight: 500; }
.p-host {
  font-size: 22rpx; background: #F59E0B; color: #FFFFFF;
  padding: 2rpx 12rpx; border-radius: 8rpx; font-weight: 500;
}
.p-status { display: flex; align-items: center; gap: 8rpx; margin-top: 6rpx; font-size: 28rpx; }
.p-ready-text { font-size: var(--fs-caption); color: var(--text-secondary); }
.p-empty-text { font-size: var(--fs-body); color: var(--text-secondary); }

/* 解散 */
.disband-area { display: flex; justify-content: center; margin-top: 24rpx; }
.disband-btn {
  font-size: var(--fs-body); color: var(--error);
  background: transparent; padding: 8rpx 0;
}

/* 底部双按钮 */
/* 密码弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 1000;
  display: flex; align-items: center; justify-content: center;
  padding: 64rpx;
}
.modal-card {
  background: var(--bg-card); border-radius: 24rpx; padding: 48rpx 40rpx 32rpx;
  width: 100%; max-width: 560rpx;
}
.modal-title { font-size: var(--fs-subtitle); font-weight: 600; color: var(--text-primary); display: block; text-align: center; }
.modal-desc { font-size: var(--fs-caption); color: var(--text-secondary); display: block; text-align: center; margin-top: 12rpx; }
.password-input {
  margin-top: 32rpx; height: 88rpx; background: var(--bg-page);
  border-radius: 16rpx; padding: 0 24rpx; font-size: 36rpx; text-align: center;
  letter-spacing: 16rpx; font-family: 'Courier New', monospace;
}
.join-error { font-size: var(--fs-caption); color: var(--error); display: block; text-align: center; margin-top: 12rpx; }
.modal-btns { display: flex; gap: 24rpx; margin-top: 32rpx; }
.modal-btns .btn-primary, .modal-btns .btn-secondary {
  height: 88rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center;
  font-size: var(--fs-body); font-weight: 500;
}
.modal-btns .btn-primary { background: var(--primary); color: var(--primary-foreground); }
.modal-btns .btn-secondary { background: var(--secondary-button); color: var(--secondary-button-foreground); }

.btn-disabled { opacity: 0.5; pointer-events: none; }

.bottom-actions {
  display: flex; gap: 24rpx; margin-top: 48rpx;
  padding-bottom: calc(env(safe-area-inset-bottom, 0) + 16rpx);
}
