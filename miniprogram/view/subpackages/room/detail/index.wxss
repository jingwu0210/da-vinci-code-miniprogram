/* 房间等待室 */
.room-page { background: #2C3A4A; min-height: 100vh; }
.main { padding: 32rpx; }
.label { font-size: 24rpx; color: #8A8A90; margin: 24rpx 0 16rpx; display: block; }
.code-box {
  height: 120rpx; display: flex; align-items: center; justify-content: center; gap: 24rpx;
  background: rgba(235,235,229,0.06); border-radius: 8rpx; border: 1rpx solid #3E4A58;
}
.code { font-size: 48rpx; font-weight: 700; color: #EBEBE5; font-family: 'Courier New', monospace; letter-spacing: 16rpx; }
.copy { font-size: 24rpx; color: #8A8A90; }
.btn-invite { width: 100%; height: 96rpx; line-height: 96rpx; margin: 24rpx 0 32rpx; background: rgba(235,235,229,0.08); color: #EBEBE5; border-radius: 8rpx; font-size: 28rpx; border: none; }
.player-row { height: 112rpx; display: flex; align-items: center; gap: 24rpx; padding: 0 24rpx; border-bottom: 1rpx solid #3E4A58; }
.p-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; background: #3E4A58; display: flex; align-items: center; justify-content: center; font-size: 28rpx; }
.p-name { font-size: 28rpx; color: #EBEBE5; display: block; }
.p-ready { font-size: 24rpx; display: block; margin-top: 4rpx; }
.p-ready.ready { color: #4A7C59; }
.p-ready.unready { color: #8A8A90; }
.placeholder .p-name { color: #8A8A90; }
.actions { display: flex; gap: 24rpx; margin-top: 48rpx; }
.btn-secondary { flex: 1; height: 96rpx; line-height: 96rpx; background: transparent; color: #8A8A90; border: 1rpx solid #3E4A58; border-radius: 8rpx; font-size: 28rpx; }
.btn-start { width: 100%; height: 96rpx; line-height: 96rpx; margin-top: 24rpx; background: rgba(235,235,229,0.08); color: #EBEBE5; border-radius: 8rpx; font-size: 32rpx; font-weight: 500; border: none; }
.btn-disband { width: 100%; height: 80rpx; line-height: 80rpx; margin-top: 16rpx; background: transparent; color: #6A4A4A; border: none; font-size: 24rpx; }
