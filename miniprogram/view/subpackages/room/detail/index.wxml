<!-- 房间等待室 -->
<view class="room-page">

  <!-- 密码输入弹窗 -->
  <view class="modal-overlay" wx:if="{{showPasswordModal}}" catchtap="onCancelJoinPassword">
    <view class="modal-card" catchtap="">
      <text class="modal-title">需要房间密码</text>
      <text class="modal-desc">房间 {{room.roomId}} 设置了密码保护</text>
      <input class="password-input" type="number" maxlength="4" placeholder="输入4位数字密码"
             value="{{joinPassword}}" bindinput="onJoinPasswordInput" focus="{{true}}" />
      <text class="join-error" wx:if="{{joinError}}">{{joinError}}</text>
      <view class="modal-btns">
        <view class="btn-secondary" style="flex:1" bindtap="onCancelJoinPassword">取消</view>
        <view class="btn-primary" style="flex:1" bindtap="onConfirmJoinWithPassword">加入房间</view>
      </view>
    </view>
  </view>

  <view class="main" wx:if="{{room}}">
    <!-- 房间码深色条 -->
    <view class="code-bar">
      <text class="code-text">房间号：{{room.roomId}}</text>
      <view class="code-actions">
        <view class="code-action" bindtap="onCopy">
          <image class="code-action-icon" mode="aspectFit" src="/images/icons/copy-white.svg" />
          <text class="code-action-text">复制</text>
        </view>
        <button class="share-btn-inline" open-type="share">
          <image class="code-action-icon" mode="aspectFit" src="/images/icons/share-white.svg" />
          <text class="code-action-text">转发</text>
        </button>
      </view>
    </view>

    <text class="label">房间成员（{{room.players.length}}/{{room.maxPlayers}}）</text>

    <view class="player-list">
      <view class="player-card" wx:for="{{room.players}}" wx:key="openid">
        <view class="p-avatar">
          <image wx:if="{{item.avatarUrl}}" class="p-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="p-avatar-placeholder">👤</text>
        </view>
        <view class="p-info">
          <view class="p-name-row">
            <text class="p-name">{{item.nickName || '玩家'}}</text>
            <text class="p-host" wx:if="{{item.openid === room.creatorOpenid}}">房主</text>
          </view>
          <view class="p-status">
            <text wx:if="{{item.isReady}}">🟢</text>
            <text wx:else>⏳</text>
            <text class="p-ready-text">{{item.isReady ? '已准备' : '未准备'}}</text>
          </view>
        </view>
      </view>
      <view class="player-card placeholder" wx:for="{{room.maxPlayers - room.players.length}}" wx:key="*this">
        <view class="p-avatar empty">👤</view>
        <text class="p-empty-text">等待加入...</text>
      </view>
    </view>

    <view class="disband-area" wx:if="{{isCreator}}">
      <text class="disband-btn" bindtap="onDisband">解散房间</text>
    </view>

    <view class="bottom-actions">
      <view class="btn-secondary" style="flex:1" bindtap="onToggleReady">{{isReady ? '取消准备' : '准备'}}</view>
      <view class="btn-primary" style="flex:1" bindtap="onStartGame" wx:if="{{isCreator && canStart}}">开始游戏</view>
      <view class="btn-primary btn-disabled" style="flex:1" wx:else>等待准备中</view>
    </view>
  </view>
</view>
