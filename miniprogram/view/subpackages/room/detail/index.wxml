<!-- 房间等待室 -->
<view class="room-page">

  <view class="main" wx:if="{{room}}">
    <!-- 房间码深色条 -->
    <view class="code-bar">
      <text class="code-text">房间号：{{room.roomId}}</text>
      <view class="code-actions">
        <text class="code-action" bindtap="onCopy">📋 复制</text>
        <button class="share-btn-inline" open-type="share">📤 转发</button>
      </view>
    </view>

    <text class="label">房间成员（{{room.players.length}}/{{room.maxPlayers}}）</text>

    <view class="player-list">
      <view class="player-card" wx:for="{{room.players}}" wx:key="openid">
        <view class="p-avatar">👤</view>
        <view class="p-info">
          <view class="p-name-row">
            <text class="p-name">{{item.nickName || '玩家'}}</text>
            <text class="p-host" wx:if="{{item.openid === room.creatorOpenid}}">房主</text>
          </view>
          <view class="p-status">
            <text wx:if="{{item.isReady}}">🟢</text>
            <text wx:else>⏳</text>
            <text class="p-ready-text">{{item.isReady ? '已准备' : '未准备'}}</text>
          </view>
        </view>
      </view>
      <view class="player-card placeholder" wx:for="{{room.maxPlayers - room.players.length}}" wx:key="*this">
        <view class="p-avatar empty">👤</view>
        <text class="p-empty-text">等待加入...</text>
      </view>
    </view>

    <view class="disband-area" wx:if="{{isCreator}}">
      <text class="disband-btn" bindtap="onDisband">解散房间</text>
    </view>

    <view class="bottom-actions">
      <button class="btn-secondary" style="flex:1" bindtap="onToggleReady">{{isReady ? '取消准备' : '准备'}}</button>
      <button class="btn-primary" style="flex:1" bindtap="onStartGame" wx:if="{{isCreator && canStart}}">开始游戏</button>
      <button class="btn-primary" style="flex:1" disabled wx:else>等待准备中</button>
    </view>
  </view>
</view>
