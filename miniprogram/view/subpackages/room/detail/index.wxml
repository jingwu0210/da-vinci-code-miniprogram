<!-- 房间等待室 -->
<view class="room-page">

  <view class="main" wx:if="{{room}}">
    <text class="label">房间码</text>
    <view class="code-box">
      <text class="code">{{room.roomId}}</text>
      <text class="copy" bindtap="onCopy">📋 复制</text>
    </view>

    <button class="btn-invite" open-type="share">📤 邀请好友</button>

    <text class="label">玩家列表</text>
    <view class="player-list">
      <view class="player-row" wx:for="{{room.players}}" wx:key="openid">
        <view class="p-avatar">👤</view>
        <view class="p-info">
          <text class="p-name">{{item.nickName || '玩家'}}{{item.openid === room.creatorOpenid ? '·房主' : ''}}</text>
          <text class="p-ready {{item.isReady ? 'ready' : 'unready'}}">{{item.isReady ? '✅ 已准备' : '⏳ 未准备'}}</text>
        </view>
      </view>
      <view class="player-row placeholder" wx:for="{{room.maxPlayers - room.players.length}}" wx:key="*this">
        <view class="p-avatar">👤</view>
        <view class="p-info"><text class="p-name">等待中...</text></view>
      </view>
    </view>

    <view class="actions">
      <button class="btn-secondary" bindtap="onToggleReady">{{isReady ? '取消准备' : '准备'}}</button>
      <button class="btn-secondary" bindtap="onLeave">离开房间</button>
    </view>
    <button class="btn-start" wx:if="{{isCreator && canStart}}" bindtap="onStartGame">开始游戏</button>
  </view>
</view>
