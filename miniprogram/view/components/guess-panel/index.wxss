/* guess-panel: 底部弹出猜测面板 */

.guess-mask {
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 99;
}

.guess-panel {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: var(--felt);
  border-top: 1rpx solid var(--divider);
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: var(--sp-md) var(--sp-lg) calc(env(safe-area-inset-bottom, 0) + var(--sp-md));
  z-index: 100;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.panel-visible { transform: translateY(0); }

.target-info {
  text-align: center; margin-bottom: var(--sp-md);
  font-size: var(--fs-body); color: var(--text-primary);
}
.target-color { color: var(--gold); margin-left: 4rpx; }

.number-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--sp-sm);
  margin-bottom: var(--sp-md);
}

.num-cell {
  height: 80rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--panel-bg);
  border: 1rpx solid var(--panel-border);
  border-radius: var(--radius-sm);
  font-size: var(--fs-body); color: var(--text-primary); font-weight: 500;
  transition: background 0.15s, border-color 0.15s;
}
.num-cell:active { background: rgba(235,235,229,0.12); }

.num-selected {
  background: var(--gold); border-color: var(--gold);
  color: #1A1A1E; font-weight: 700;
}

.joker-cell { grid-column: span 4; }
.joker-label { font-size: var(--fs-subtitle); font-family: 'Courier New', 'SF Mono', monospace; }
.num-label { font-size: var(--fs-body); }

.guess-actions { display: flex; gap: var(--sp-md); margin-bottom: var(--sp-sm); }

.btn-cancel {
  flex: 1; height: 80rpx; line-height: 80rpx;
  background: transparent; color: var(--text-secondary);
  border: 1rpx solid var(--divider); border-radius: var(--radius-sm);
  font-size: var(--fs-body);
}
.btn-confirm {
  flex: 2; height: 80rpx; line-height: 80rpx;
  background: rgba(235,235,229,0.08); color: var(--text-secondary);
  border: none; border-radius: var(--radius-sm);
  font-size: var(--fs-body);
}
.btn-confirm.btn-active {
  background: var(--gold); color: #1A1A1E; font-weight: 600;
}
.btn-confirm[disabled] { opacity: 0.4; }

.end-turn-area {
  display: flex; justify-content: center;
  padding-top: var(--sp-sm); border-top: 1rpx solid var(--divider);
}
.btn-end-turn {
  height: 64rpx; line-height: 64rpx;
  background: transparent; color: var(--error);
  font-size: var(--fs-caption); border: none;
}
