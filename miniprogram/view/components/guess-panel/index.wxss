/* guess-panel: 内嵌底部猜测面板 */

.guess-panel {
  padding: 20rpx var(--sp-md) 16rpx;
}

/* 目标信息 */
.target-info {
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
  margin-bottom: 20rpx;
  font-size: var(--fs-body); color: var(--text-primary); font-weight: 500;
}
.target-name { color: var(--primary); font-weight: 600; }
.target-color { font-size: var(--fs-caption); color: var(--gold); }

/* 数字网格 */
.number-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.num-cell {
  height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  background: var(--bg-page);
  border: 2rpx solid var(--divider);
  border-radius: 16rpx;
  font-size: 32rpx; color: var(--text-primary); font-weight: 600;
  transition: all 0.15s;
}
.num-cell:active { background: var(--divider); transform: scale(0.96); }

.num-selected {
  background: var(--primary); border-color: var(--primary);
  color: var(--primary-foreground);
  box-shadow: 0 2rpx 8rpx rgba(31,41,55,0.25);
}

/* Joker 按钮 */
.joker-cell { grid-column: span 4; }
.joker-cell.num-selected { background: var(--gold); border-color: var(--gold); color: #1F2937; }
.joker-label {
  font-size: 34rpx; font-weight: 700;
  font-family: Georgia, 'Times New Roman', serif;
  letter-spacing: 2rpx;
}
.num-label { font-size: 32rpx; font-weight: 600; }

/* 操作按钮 */
.guess-actions { display: flex; gap: 16rpx; }

.btn-cancel {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: var(--bg-page); color: var(--text-secondary);
  border: 2rpx solid var(--divider); border-radius: 16rpx;
  font-size: var(--fs-body); font-weight: 500;
}
.btn-cancel:active { background: var(--divider); }

.btn-confirm {
  flex: 2; height: 88rpx; line-height: 88rpx; text-align: center;
  background: var(--divider); color: var(--text-muted);
  border: none; border-radius: 16rpx;
  font-size: var(--fs-body); font-weight: 500;
  transition: all 0.2s;
}
.btn-confirm.btn-active {
  background: var(--primary); color: var(--primary-foreground);
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(31,41,55,0.2);
}
.btn-confirm[disabled] { opacity: 0.5; }
