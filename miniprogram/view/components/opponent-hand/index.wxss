/* opponent-hand: 对手手牌行 */

.opponent-scroll {
  width: 100%; height: 160rpx;
  white-space: nowrap;
}

.opponent-hand {
  display: inline-flex; align-items: center; gap: var(--tile-gap);
  height: 160rpx;
}

.tile-cell {
  display: inline-flex; flex-shrink: 0;
  transition: transform 0.2s ease;
  cursor: pointer;
}
.tile-cell.tile-targeted {
  transform: translateY(-8rpx);
}
.tile-spacer {
  width: 48rpx; flex-shrink: 0;
}

.empty-slot {
  width: 80rpx; height: 160rpx;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-secondary); font-size: var(--fs-caption);
  opacity: 0.3;
}
