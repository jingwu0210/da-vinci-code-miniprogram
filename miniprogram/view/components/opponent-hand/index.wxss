/* opponent-hand: 对手手牌 */

.opponent-section {
  padding: var(--sp-sm) var(--sp-md);
  border-radius: var(--radius-md);
  transition: background 0.2s ease;
  margin-bottom: var(--sp-xs);
}
.opponent-section.target-active {
  background: rgba(158,140,108,0.08);
  border: 1rpx solid rgba(158,140,108,0.15);
}

.opponent-label {
  display: flex; align-items: center; gap: 4rpx;
  margin-bottom: var(--sp-xs);
}
.opponent-name {
  font-size: var(--fs-caption); color: var(--text-secondary); font-weight: 500;
}
.opponent-status {
  font-size: var(--fs-caption); color: var(--gold);
}

.opponent-scroll {
  width: 100%; height: 180rpx;
  white-space: nowrap;
}

.opponent-hand {
  display: inline-flex; align-items: center; gap: var(--tile-gap);
  height: 180rpx;
}

.tile-cell {
  display: inline-flex; flex-shrink: 0;
  transition: transform 0.2s ease;
  cursor: pointer;
}
.tile-spacer {
  width: 48rpx; flex-shrink: 0;
}
.tile-cell.tile-targeted {
  transform: translateY(-8rpx);
}

.empty-slot {
  width: 80rpx; height: 160rpx;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-secondary); font-size: var(--fs-caption);
  opacity: 0.3;
}
