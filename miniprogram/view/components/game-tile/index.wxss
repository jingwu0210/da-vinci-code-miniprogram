/* game-tile: 实体多米诺牌风格 */

/* === 尺寸 === */
.tile-wrapper {
  position: relative; display: inline-flex; flex-shrink: 0;
  perspective: 300rpx;
}
.size-large  { width: 104rpx; height: 156rpx; }
.size-medium { width: 80rpx;  height: 124rpx; }
.size-small  { width: 60rpx;  height: 96rpx;  }

/* === 主体（多米诺骨牌风格） === */
.tile-inner {
  position: relative; width: 100%; height: 100%; border-radius: 10rpx;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  z-index: 1; box-sizing: border-box;
  box-shadow: 0 6rpx 0 rgba(0,0,0,0.3), 0 8rpx 16rpx rgba(0,0,0,0.25);
}
.tile-black {
  background: #0A0A0A;
}
.tile-black::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, transparent 50%);
  border-radius: 10rpx; pointer-events: none; z-index: 0;
}
.tile-white {
  background: #E6E6DE;
  box-shadow: 0 6rpx 0 rgba(0,0,0,0.18), 0 8rpx 16rpx rgba(0,0,0,0.2);
}
.tile-white.size-large  { width:100rpx; height:150rpx; }
.tile-white.size-medium { width:76rpx;  height:118rpx; }
.tile-white.size-small  { width:56rpx;  height:90rpx;  }
.tile-white::after {
  content: ''; position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.3) 0%, transparent 50%);
  border-radius: 10rpx; pointer-events: none; z-index: 0;
}

/* === 正面数字 === */
.tile-value {
  display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 2;
  margin-top: -10rpx;
}
.num-underline { width: 48rpx; height: 2rpx; margin-top: 6rpx; border-radius: 1rpx; }
.ul-dark  { background: #777; }
.ul-light { background: #222; }
.val-dark { color: #F0F0E8; }
.val-light { color: #1A1A1E; }
.number-text { font-family: 'PingFang SC', 'Helvetica Neue', sans-serif; font-weight: 800; line-height: 1; text-align:center; display:inline-block; }
.two-digit { font-size: 0.68em; letter-spacing: -2rpx; }
.joker-text  { font-family: 'PingFang SC', 'Helvetica Neue', sans-serif; font-weight: 800; color: var(--gold); line-height: 1; text-align:center; }
.size-large  .number-text { font-size: 60rpx; }
.size-medium .number-text { font-size: 46rpx; }
.size-small  .number-text { font-size: 34rpx; }
.size-large  .joker-text  { font-size: 40rpx; }
.size-medium .joker-text  { font-size: 30rpx; }
.size-small  .joker-text  { font-size: 24rpx; }

/* === 背面 === */
.tile-back { display: flex; align-items: center; justify-content: center; z-index: 2; }
.back-symbol { font-weight: 300; line-height: 1; opacity: 0.5; }
.back-dark  { color: #5A5A60; }
.back-light { color: #A0A098; }
.size-large  .back-symbol { font-size: 48rpx; }
.size-medium .back-symbol { font-size: 38rpx; }
.size-small  .back-symbol { font-size: 30rpx; }

/* === 状态 === */
.tile-wrapper.selected .tile-inner {
  border: 2rpx solid var(--gold);
  box-shadow: 0 0 20rpx rgba(158,140,108,0.6);
}
.tile-wrapper.selected:not(.revealed) .tile-inner {
  transform: translateY(-8rpx);
}
.tile-wrapper.disabled { opacity: 0.7; pointer-events: none; }
.tile-wrapper.drawn {
  transform: translateY(-24rpx);
  filter: drop-shadow(0 8rpx 28rpx rgba(158,140,108,0.4));
}

/* 已翻开标记：金色边框 */
.revealed-mark {
  display: none;
}
.tile-wrapper.own-revealed .tile-inner {
  box-shadow: 0 0 0 2rpx #8B4A4A;
}
.tile-wrapper.opp-revealed .tile-inner {
  box-shadow: 0 0 0 2rpx #4A7C59;
}

/* 已翻开永久倾斜 */
.tile-wrapper.revealed .tile-inner {
  transform: rotateX(45deg);
  transform-origin: 50% 100%;
}

/* === 浮现数字层 === */
.reveal-overlay {
  display: none; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  flex-direction: column; align-items: center; justify-content: center; z-index: 20; border-radius: 6rpx;
  font-family: 'Courier New', 'SF Mono', monospace; font-weight: 700;
}
.reveal-overlay.show { display: flex; }
.overlay-dark  { background: rgba(20,20,24,0.92); color: #F0F0E8; }
.overlay-light { background: rgba(235,235,229,0.92); color: #1A1A1E; }
.ov-num { line-height: 1; }
.ov-num.two-digit { font-size: 0.72em; letter-spacing: -2rpx; }
.size-large  .ov-num { font-size: 60rpx; }
.size-medium .ov-num { font-size: 46rpx; }
.size-small  .ov-num { font-size: 34rpx; }
.ov-joker { color: var(--gold); line-height: 1; }
.size-large  .ov-joker { font-size: 40rpx; }
.size-medium .ov-joker { font-size: 30rpx; }
.size-small  .ov-joker { font-size: 24rpx; }

/* === 推倒动画（3D rotateX 模拟多米诺被推倒，最终停在小角度倾斜） === */
.tile-inner { transform-style: preserve-3d; }
@keyframes tile-topple {
  0%   { transform: rotateX(0deg); }
  10%  { transform: rotateX(-3deg); }
  20%  { transform: rotateX(2deg); }
  30%  { transform: rotateX(0deg); }
  50%  { transform: rotateX(65deg); }
  70%  { transform: rotateX(40deg); }
  85%  { transform: rotateX(48deg); }
  100% { transform: rotateX(45deg); }
}
.was-revealed .tile-inner {
  animation: tile-topple 0.7s ease-out forwards;
  transform-origin: 50% 100%;
}
