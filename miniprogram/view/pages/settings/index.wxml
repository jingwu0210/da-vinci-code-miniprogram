<!-- 设置页 -->
<view class="settings-page">
  <view class="section">
    <view class="label">游戏设置</view>
    <view class="row"><text>音效</text><switch checked="{{settings.soundEnabled}}" bindchange="onToggleSound" /></view>
    <view class="row"><text>振动</text><switch checked="{{settings.vibrationEnabled}}" bindchange="onToggleVibration" /></view>
  </view>
  <view class="section" wx:if="{{userType !== 'wechat'}}">
    <view class="label">数据</view>
    <view class="row" bindtap="onClearHistory"><text>清除历史对局</text><text class="row-arrow">›</text></view>
  </view>
</view>
