.settings-page { background: var(--bg-page); min-height: 100vh; padding: 24rpx 32rpx; }

/* 设置卡片 */
.settings-card {
  background: var(--bg-card); border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  overflow: hidden;
}

.setting-row {
  display: flex; align-items: center; justify-content: space-between;
  height: 104rpx; padding: 0 32rpx;
  font-size: var(--fs-subtitle); color: var(--text-primary); font-weight: 500;
}

.setting-divider {
  height: 1rpx; background: var(--divider); margin-left: 32rpx;
}

.setting-label { font-size: var(--fs-subtitle); color: var(--text-primary); }

.setting-arrow { font-size: 40rpx; color: var(--text-secondary); }

.setting-value { font-size: var(--fs-body); color: var(--text-secondary); }

/* 退出登录 */
.logout-area {
  display: flex; justify-content: center; margin-top: 48rpx;
  padding-bottom: calc(env(safe-area-inset-bottom, 0) + 32rpx);
}

switch {
  transform: scale(0.85);
}
