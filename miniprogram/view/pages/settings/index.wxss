.settings-page { background: #2C3A4A; min-height: 100vh; padding: 24rpx 32rpx; }
.section { margin-bottom: 48rpx; }
.label { font-size: 24rpx; color: #8A8A90; margin-bottom: 16rpx; }
.row { display: flex; align-items: center; justify-content: space-between; height: 80rpx; font-size: 28rpx; color: #EBEBE5; border-bottom: 1rpx solid #3E4A58; padding: 0 8rpx; }
.row-arrow { font-size: 36rpx; color: #8A8A90; }
.guest-hint { font-size: 24rpx; color: #8A8A90; line-height: 1.6; }
.row-hint { font-size: 22rpx; color: #5A5A60; padding: 4rpx 8rpx 8rpx; }
.avatar-btn { width: 96rpx; height: 96rpx; padding: 0; border: none; background: none; }
.avatar-btn::after { border: none; }
.s-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: #3E4A58; display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.s-input { width: 100%; height: 80rpx; background: rgba(235,235,229,0.06); border: 1rpx solid #3E4A58; border-radius: 8rpx; color: #EBEBE5; font-size: 28rpx; padding: 0 24rpx; box-sizing: border-box; margin-top: 16rpx; }
