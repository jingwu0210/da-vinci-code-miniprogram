<!-- 大厅页 -->
<view class="lobby-page">
  <!-- 自定义导航栏：深色底 -->
  <view class="nav-bar" style="padding-top:{{statusBarHeight + 8}}px; padding-bottom:12rpx">
    <view class="nav-left" bindtap="onTapSettings">
      <image class="nav-avatar" src="{{user.avatarUrl}}" mode="aspectFill" wx:if="{{user.avatarUrl}}"/>
      <view class="nav-avatar-placeholder" wx:else>👤</view>
      <view class="nav-user">
        <text class="nav-nick">{{user.nickName || '玩家'}}</text>
        <text class="nav-stats">胜 {{user.stats.wins || 0}} · 负 {{user.stats.losses || 0}} · 胜率 {{winRate}}%</text>
      </view>
    </view>
  </view>

  <scroll-view class="main" scroll-y enhanced show-scrollbar="{{false}}">
    <!-- Hero -->
    <view class="hero" style="padding-top:{{heroTopPadding}}px">
      <text class="hero-title">达芬奇密码</text>
      <text class="hero-sub">逻辑推理 · 洞察人心</text>
    </view>

    <view class="section-gap"></view>

    <!-- 牌组装饰 -->
    <view class="tile-row">
      <view class="deco-tile black"><text class="deco-num">3</text></view>
      <view class="deco-tile white"><text class="deco-num w">5</text></view>
      <view class="deco-tile black"><text class="deco-num" style="color:#C9A84C;font-size:36rpx">—</text></view>
      <view class="deco-tile black"><text class="deco-num">11</text></view>
      <view class="deco-tile white"><text class="deco-num w">7</text></view>
    </view>

    <view class="section-gap"></view>

    <!-- 主按钮区 -->
    <view class="btn-section">
      <view class="lobby-btn" bindtap="onTapAi">
        <image class="lobby-btn-icon" src="/images/icons/bot.svg" />
        <text class="lobby-btn-title">单机人机对战</text>
      </view>

      <view class="lobby-btn" bindtap="onTapFriends">
        <image class="lobby-btn-icon" src="/images/icons/users.svg" />
        <text class="lobby-btn-title">好友房间</text>
      </view>

      <view class="lobby-btn" bindtap="onTapTutorial">
        <image class="lobby-btn-icon" src="/images/icons/book-open.svg" />
        <text class="lobby-btn-title">游戏规则</text>
      </view>

      <view class="lobby-btn" bindtap="onTapHistory">
        <image class="lobby-btn-icon" src="/images/icons/clipboard.svg" />
        <text class="lobby-btn-title">历史对局</text>
      </view>

      <view class="lobby-btn" bindtap="onTapSettings">
        <image class="lobby-btn-icon" src="/images/icons/settings.svg" />
        <text class="lobby-btn-title">系统设置</text>
      </view>
    </view>

    <view class="section-gap"></view>

    <view class="footer">
      <text class="footer-text">V1.0 · 经典推理桌游</text>
    </view>
  </scroll-view>

  <!-- 好友房间弹窗 -->
  <view class="modal-mask" wx:if="{{showRoomModal}}" bindtap="onCancelRoomModal"></view>
  <view class="modal-panel" wx:if="{{showRoomModal}}">
    <text class="modal-title">好友房间</text>

    <view wx:if="{{!showJoinInput}}">
      <button class="btn-primary" bindtap="onTapCreateRoom">创建房间</button>
      <button class="btn-secondary" bindtap="onTapShowJoin" style="margin-top:16rpx">加入房间</button>
      <view class="btn-ghost" bindtap="onCancelRoomModal" style="margin-top:16rpx">取消</view>
    </view>

    <view wx:else>
      <input class="input-field" type="text" maxlength="6" placeholder="6位房间码" value="{{roomCode}}" bindinput="onRoomCodeInput" style="letter-spacing:16rpx;font-family:'Courier New',monospace;margin-bottom:16rpx"/>
      <input class="input-field" type="number" maxlength="4" placeholder="4位密码（选填）" value="{{roomPassword}}" bindinput="onRoomPasswordInput" style="letter-spacing:8rpx;font-family:'Courier New',monospace;margin-bottom:20rpx"/>
      <button class="btn-primary" bindtap="onConfirmJoin">确认加入</button>
      <view class="btn-ghost" bindtap="onCancelJoinInput" style="margin-top:12rpx">取消</view>
    </view>
  </view>
</view>
