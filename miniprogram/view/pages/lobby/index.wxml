<!-- 大厅页 -->
<view class="lobby-page">
  <view class="top-bar">
    <text class="top-exit" catchtap="onTapExit">‹ 退出</text>
    <text class="top-title">达芬奇密码</text>
    <view class="top-spacer"></view>
  </view>
  <scroll-view class="main" scroll-y>
    <view class="user-card" bindtap="onTapSettings">
      <image class="avatar-img" src="{{user.avatarUrl}}" mode="aspectFill" wx:if="{{user.avatarUrl}}"/>
      <view class="avatar" wx:else>👤</view>
      <view class="user-info">
        <view class="nick">{{user.nickName || '玩家A'}}</view>
        <view class="stats" wx:if="{{user.stats}}">胜 {{user.stats.wins}} · 负 {{user.stats.losses}} · 胜率 {{winRate}}%</view>
      </view>
      <text class="card-arrow">›</text>
    </view>

    <view class="mode-section">
      <view class="mode-btn ai" bindtap="onTapAi">
        <text class="mode-icon">🤖</text>
        <view class="mode-info"><text class="mode-title">人机对战</text><text class="mode-desc">选择难度，与 AI 一决高下</text></view>
        <text class="mode-arrow">→</text>
      </view>
      <view class="mode-btn friends" bindtap="onTapFriends">
        <text class="mode-icon">👥</text>
        <view class="mode-info"><text class="mode-title">好友联机</text><text class="mode-desc">创建/加入房间，邀请好友</text></view>
        <text class="mode-arrow">→</text>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <text class="tab" bindtap="onTapTutorial">📖 玩法说明</text>
    <text class="tab" bindtap="onTapHistory">📋 历史对局</text>
  </view>

  <!-- 难度选择弹窗 -->
  <view class="modal-mask" wx:if="{{showDifficulty}}" bindtap="onCancelDifficulty"></view>
  <view class="modal-panel" wx:if="{{showDifficulty}}">
    <text class="modal-title">选择 AI 难度</text>
    <view class="diff-list">
      <view class="diff-item {{selectedDifficulty === 'easy' ? 'active' : ''}}" data-diff="easy" bindtap="onSelectDifficulty">
        <text class="diff-name">简单</text><text class="diff-hint">随机决策，适合新手</text>
      </view>
      <view class="diff-item {{selectedDifficulty === 'medium' ? 'active' : ''}}" data-diff="medium" bindtap="onSelectDifficulty">
        <text class="diff-name">中等</text><text class="diff-hint">逻辑推理，旗鼓相当</text>
      </view>
      <view class="diff-item {{selectedDifficulty === 'hard' ? 'active' : ''}}" data-diff="hard" bindtap="onSelectDifficulty">
        <text class="diff-name">困难</text><text class="diff-hint">概率矩阵，最强挑战</text>
      </view>
    </view>
    <view class="modal-btns">
      <button class="modal-cancel" bindtap="onCancelDifficulty">取消</button>
      <button class="modal-confirm" bindtap="onConfirmAi">开始对战</button>
    </view>
  </view>
</view>
