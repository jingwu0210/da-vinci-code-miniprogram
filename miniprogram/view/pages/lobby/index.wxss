.lobby-page { background: var(--bg-page); min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; width: 100vw; box-sizing: border-box; }

/* === 自定义导航栏（深色） === */
.nav-bar {
  display: flex; align-items: center; justify-content: space-between;
  padding-left: 32rpx; padding-right: 32rpx; padding-bottom: 20rpx;
  background: #1F2937; box-sizing: border-box;
}
.nav-left { display: flex; align-items: center; gap: 16rpx; flex:1; }
.nav-avatar, .nav-avatar-placeholder {
  width: 72rpx; height: 72rpx; border-radius: 50%; flex-shrink: 0;
}
.nav-avatar-placeholder {
  background: #374151; display: flex; align-items: center; justify-content: center;
  font-size: 36rpx; color: #9CA3AF;
}
.nav-user { display: flex; flex-direction: column; gap: 4rpx; flex:1; }
.nav-nick { font-size: 30rpx; font-weight: 500; color: #FFFFFF; }
.nav-stats { font-size: 22rpx; color: #9CA3AF; }

/* === 主体 === */
.main { flex: 1; width: 100%; box-sizing: border-box; }

/* === Hero === */
.hero { text-align: center; padding-left: 32rpx; padding-right: 32rpx; }
.hero-title { font-size: 52rpx; font-weight: 700; color: #C9A84C; display: block; }
.hero-sub { font-size: 26rpx; color: var(--text-secondary); display: block; margin-top: 12rpx; }

/* === 区块间距 === */
.section-gap { height: 56rpx; flex-shrink:0; }

/* === 牌组装饰 === */
.tile-row { display: flex; justify-content: center; gap: 16rpx; padding: 0 32rpx; flex-shrink:0; }
.deco-tile {
  width: 80rpx; height: 116rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
}
.deco-tile.black { background: #111827; }
.deco-tile.white { background: #F9FAFB; border: 1rpx solid #D1D5DB; }
.deco-num { font-size: 30rpx; font-weight: 700; color: #FFFFFF; font-family: Georgia, serif; }
.deco-num.w { color: #111827; }

/* === 主入口：2 列卡片 === */
.card-grid {
  display: flex; gap: 24rpx; padding: 0 32rpx; flex-shrink:0;
}
.entry-card {
  flex: 1; background: var(--primary); border-radius: 24rpx;
  padding: 40rpx 24rpx; display: flex; flex-direction: column;
  align-items: center; gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}
.entry-card:active { opacity: 0.85; }
.entry-card-icon { width: 56rpx; height: 56rpx; flex-shrink: 0; }
.entry-card-title { font-size: var(--fs-subtitle); font-weight: 600; color: #FFFFFF; }
.entry-card-desc { font-size: var(--fs-caption); color: rgba(255,255,255,0.6); }

/* === 底部标签栏 === */
.link-row {
  display: flex; align-items: center; justify-content: center;
  padding: 40rpx 0 0; flex-shrink:0; gap: 0;
}
.link-item {
  display: flex; align-items: center; gap: 8rpx;
  font-size: var(--fs-body); color: var(--text-secondary);
  padding: 8rpx 24rpx;
}
.link-icon { width: 32rpx; height: 32rpx; flex-shrink: 0; opacity: 0.6; }
.link-divider {
  width: 1rpx; height: 28rpx; background: var(--divider);
}

/* === Footer === */
.footer { text-align: center; padding: 32rpx 0 calc(env(safe-area-inset-bottom, 0) + 32rpx); flex-shrink:0; }
.footer-text { font-size: var(--fs-caption); color: var(--text-secondary); }

/* === 弹窗 === */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.modal-panel {
  position: fixed; left: 60rpx; right: 60rpx; top: 40%;
  background: var(--bg-card); border-radius: 32rpx;
  padding: 40rpx 32rpx; z-index: 101;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}
.modal-title { font-size: var(--fs-subtitle); font-weight: 600; color: var(--text-primary); display: block; text-align: center; margin-bottom: 24rpx; }

.modal-panel .btn-primary,
.modal-panel .btn-secondary { width: 100%; }
