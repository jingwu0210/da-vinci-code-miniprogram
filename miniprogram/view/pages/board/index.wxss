/* board: 游戏主界面 */

@import '../../../common/theme.wxss';

.board-page {
  display: flex; flex-direction: column;
  height: 100vh; background: var(--bg-page);
  overflow: hidden;
}

/* === 自定义顶栏（深色） === */
.board-top-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 var(--sp-md) 20rpx; flex-shrink: 0;
  background: #1F2937; box-sizing: border-box;
}
.board-turn { font-size: var(--fs-body); color: #FFFFFF; font-weight: 500; }
.board-quit { display:flex; align-items:center; gap:6rpx; font-size: var(--fs-body); color: #9CA3AF; }
.quit-icon { width:32rpx; height:32rpx; }

/* === 离线横幅 === */
.offline-banner {
  background: var(--error); color: #FFFFFF;
  text-align: center; padding: var(--sp-xs) 0;
  font-size: var(--fs-caption); flex-shrink: 0;
}

/* === 主滚动区 === */
.board-scroll {
  flex: 1; padding: var(--sp-sm) var(--sp-md);
  box-sizing: border-box;
}

/* === 对手卡片 === */
.opponent-card {
  background: var(--bg-card); border-radius: 24rpx;
  padding: 20rpx 24rpx; margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  box-sizing: border-box; overflow: hidden;
  border-left: 8rpx solid transparent;
}
.opponent-card.active-turn {
  border-left-color: #3B82F6;
}
.opponent-card-header {
  display: flex; align-items: center; gap: 4rpx; margin-bottom: 8rpx;
}
.opponent-card-name {
  font-size: var(--fs-caption); color: var(--text-secondary); font-weight: 500;
}

/* === 状态提示 === */
.board-status {
  text-align: center; padding: 16rpx 0;
  font-size: var(--fs-caption); color: var(--text-secondary);
}

/* === 我的手牌卡片 === */
.self-card {
  background: var(--bg-card); border-radius: 24rpx;
  padding: 16rpx 24rpx 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  margin-bottom: var(--sp-sm);
  border-left: 8rpx solid transparent;
}
.self-card.active-turn {
  border-left-color: #3B82F6;
}
.self-card-label {
  font-size: var(--fs-caption); color: var(--text-secondary);
  display: block; margin-bottom: 4rpx;
}
.turn-hint {
  color: var(--gold);
}

/* === 底部操作栏 === */
/* === 对手行动通知条（手牌下方，醒目但不遮挡） === */
.board-notify {
  text-align: center; margin: 24rpx 32rpx 0;
  padding: 18rpx 28rpx;
  background: var(--primary); border-radius: 24rpx;
  font-size: 26rpx; color: var(--primary-foreground); font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(31,41,55,0.25);
}

.action-area {
  flex-shrink: 0;
  padding: var(--sp-sm) var(--sp-md) calc(env(safe-area-inset-bottom, 0) + var(--sp-sm));
  background: var(--bg-card); border-top: 1rpx solid var(--divider);
}

/* === 摸牌按钮 === */
.draw-choices { display: flex; gap: var(--sp-md); }
.draw-btn {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  height: 140rpx; border-radius: 24rpx;
}
.draw-btn:active { opacity: 0.85; }
.draw-btn-disabled { opacity: 0.3; pointer-events: none; }
.draw-black {
  background: var(--black-tile);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
}
.draw-white {
  background: var(--white-tile);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}
.draw-label { font-size: var(--fs-body); font-weight: 500; margin-top: 4rpx; }
.draw-black .draw-label { color: var(--text-on-black); }
.draw-white .draw-label { color: var(--text-on-white); }
.draw-count { font-size: var(--fs-caption); margin-top: 4rpx; }
.draw-black .draw-count { color: rgba(216,212,204,0.6); }
.draw-white .draw-count { color: rgba(58,56,52,0.6); }

/* === 猜测提示 === */
.guess-hint {
  text-align: center; font-size: var(--fs-body);
  color: var(--gold); padding: var(--sp-lg) 0;
}

/* === 猜对后操作 === */
.post-guess {
  display: flex; gap: var(--sp-md); padding: var(--sp-md) 0;
}
.btn-continue {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: rgba(16,185,129,0.1); color: var(--success);
  border: 1rpx solid var(--success); border-radius: 24rpx;
  font-size: var(--fs-body);
}
.btn-end-turn {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: var(--bg-card); color: var(--text-primary);
  border: 1rpx solid var(--divider); border-radius: 24rpx;
  font-size: var(--fs-body);
}
