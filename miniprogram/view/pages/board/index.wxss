/* board: 游戏主界面 */

@import '../../../common/theme.wxss';

.board-page {
  display: flex; flex-direction: column;
  height: 100vh; background: var(--bg-page);
  overflow: hidden;
}

/* === 自定义顶栏（深色） === */
.board-top-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 0 var(--sp-md); flex-shrink: 0;
  background: #1F2937; box-sizing: border-box;
}
.board-turn { font-size: var(--fs-body); color: #FFFFFF; font-weight: 500; }
.board-quit { font-size: var(--fs-body); color: #EF4444; }

/* === 离线横幅 === */
.offline-banner {
  background: var(--error); color: var(--text-primary);
  text-align: center; padding: var(--sp-xs) 0;
  font-size: var(--fs-caption); flex-shrink: 0;
}

/* === 对手区域 === */
.opponents-area {
  flex: 1; padding: var(--sp-xs) 0; overflow-y: auto;
}

/* === 分隔线 === */
.board-divider {
  height: 2rpx; background: var(--divider);
  margin: 0 var(--sp-md); flex-shrink: 0;
}

/* === 状态引导条 === */
.board-status {
  text-align: center; padding: 16rpx 0; flex-shrink: 0;
  font-size: var(--fs-body); color: var(--text-secondary);
}

/* === 自己手牌 === */
.self-area {
  padding: var(--sp-md) var(--sp-md); flex-shrink: 0;
  /* 手牌区上移，下方留 gap 给猜测面板 */
}

/* === 操作区 === */
.action-area {
  flex-shrink: 0; margin-top: auto;
  padding: var(--sp-sm) var(--sp-md) calc(env(safe-area-inset-bottom, 0) + var(--sp-sm));
  background: var(--bg-card); border-top: 1rpx solid var(--divider);
}

.waiting-hint {
  text-align: center; font-size: var(--fs-body);
  color: var(--text-secondary); padding: var(--sp-lg) 0;
}

/* === 摸牌按钮 === */
.draw-choices { display: flex; gap: var(--sp-md); }

.draw-btn {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  height: 140rpx;
  background: var(--bg-card); border: 1rpx solid var(--divider);
  border-radius: 24rpx;
}
.draw-btn:active { background: var(--bg-card-hover); }
.draw-btn-disabled { opacity: 0.3; pointer-events: none; }

.draw-emoji { font-size: 40rpx; line-height: 1; }
.draw-label { font-size: var(--fs-body); color: var(--text-primary); font-weight: 500; margin-top: 4rpx; }
.draw-count { font-size: var(--fs-caption); color: var(--text-secondary); margin-top: 4rpx; }

/* === 插牌提示 === */
.insert-hint {
  text-align: center; font-size: var(--fs-body);
  color: var(--insert-gold); padding: var(--sp-lg) 0;
}

/* === 猜测提示（未选目标）=== */
.guess-hint {
  text-align: center; font-size: var(--fs-body);
  color: var(--gold); padding: var(--sp-lg) 0;
}

/* === 猜对后操作 === */
.post-guess {
  display: flex; gap: var(--sp-md); padding: var(--sp-md) var(--sp-lg);
}
.btn-continue {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: rgba(16,185,129,0.1); color: var(--success);
  border: 1rpx solid var(--success); border-radius: 24rpx;
  font-size: var(--fs-body);
}
.btn-end-turn {
  flex: 1; height: 88rpx; line-height: 88rpx; text-align: center;
  background: var(--bg-card); color: var(--text-primary);
  border: 1rpx solid var(--divider); border-radius: 24rpx;
  font-size: var(--fs-body);
}
