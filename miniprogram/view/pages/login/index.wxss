.login-page { background:var(--bg-page); min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:0 60rpx; overflow-x:hidden; width:100vw; box-sizing:border-box; }

/* === 牌组展示：错落堆叠 === */
.hero { position:relative; width:340rpx; height:210rpx; margin-bottom:48rpx; }
.hero-card { position:absolute; }
.hero-tile { width:80rpx; height:112rpx; border-radius:6rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.3); }
.hero-tile.black { background:#1E1E22; }
.hero-tile.white { background:#E8E4DC; }
.hero-num { font-family:'PingFang SC',sans-serif; font-weight:700; font-size:40rpx; line-height:1; color:#D8D4CC; }
.hero-tile.white .hero-num { color:#3A3834; }
.hero-line { width:36rpx; height:1rpx; margin-top:4rpx; background:rgba(255,255,255,0.15); }
.white-line { background:rgba(0,0,0,0.15); }

/* 4 张牌横向扇形展开 */
.c1 { top:56rpx; left:0; transform:rotate(-12deg); z-index:2; }
.c2 { top:0; left:76rpx; transform:rotate(6deg); z-index:1; }
.c3 { top:28rpx; left:148rpx; transform:rotate(-4deg); z-index:3; }
.c4 { top:72rpx; left:218rpx; transform:rotate(14deg); z-index:2; }

/* === 品牌 === */
.brand { text-align:center; margin-bottom:64rpx; }
.brand-title { font-size:42rpx; font-weight:700; color:#C9A84C; letter-spacing:10rpx; line-height:1.5; }
.brand-sub { font-size:26rpx; color:#6B7280; margin-top:4rpx; }

/* === 按钮 === */
.actions { display:flex; flex-direction:column; align-items:center; width:100%; gap:20rpx; margin-bottom:48rpx; }
.btn {
  width:600rpx; height:96rpx; border-radius:24rpx; font-size:var(--fs-subtitle);
  display:flex; align-items:center; justify-content:center; gap:12rpx;
  font-weight:500;
}
.btn-wechat {
  background:var(--primary); color:var(--primary-foreground);
  box-shadow:0 2rpx 4rpx rgba(0,0,0,0.1);
}
.btn-wechat:active { opacity:0.85; }
.btn-guest {
  background:var(--secondary-button); color:var(--secondary-button-foreground);
  box-shadow:0 2rpx 4rpx rgba(0,0,0,0.06);
}
.btn-guest:active { opacity:0.85; }
.btn-start {
  background:var(--primary); color:var(--primary-foreground);
  box-shadow:0 2rpx 4rpx rgba(0,0,0,0.1);
}
.btn-start:active { opacity:0.85; }

/* loading spinner */
.btn-spinner {
  width:36rpx; height:36rpx; border:4rpx solid rgba(255,255,255,0.3);
  border-top-color:#FFFFFF; border-radius:50%;
  animation:spin 0.8s linear infinite;
}
@keyframes spin { from { transform:rotate(0deg); } to { transform:rotate(360deg); } }

/* === 协议 === */
.agreement { position:absolute; bottom:0; left:0; right:0; text-align:center; padding: 32rpx 0 calc(env(safe-area-inset-bottom, 0) + 32rpx); }
.agree-text { font-size:22rpx; color:#6B7280; }
.agree-link { font-size:22rpx; color:var(--link); text-decoration:underline; }

/* === 头像昵称 === */
.profile-setup { display:flex; flex-direction:column; align-items:center; gap:24rpx; width:100%; margin-bottom:64rpx; }
.avatar-wrapper { position:relative; width:120rpx; height:120rpx; }
.profile-avatar { width:120rpx; height:120rpx; border-radius:50%; border:2rpx solid var(--divider); display:block; box-sizing:border-box; }
.avatar-trigger { position:absolute; inset:0; border-radius:50%; background:transparent; border:none; padding:0; opacity:0; }
.avatar-trigger::after { border:none; }
.input-nickname { width:100%; height:96rpx; border-radius:16rpx; background:var(--bg-card); border:1rpx solid var(--divider); color:var(--text-primary); font-size:var(--fs-body); text-align:center; box-sizing:border-box; padding:0 24rpx; }
