/* 登录页 — 匹配 Figma LoginPage */
.login-page {
  background: #2C3A4A;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  position: relative;
  overflow-x: hidden;
  width: 100vw;
  max-width: 100vw;
  box-sizing: border-box;
}
.decorative-tiles {
  position: relative;
  height: 160rpx;
  width: 560rpx;
  margin-bottom: 96rpx;
  opacity: 0.6;
}
.dec-tile {
  position: absolute;
}
.brand { text-align: center; margin-bottom: 96rpx; }
.brand-title {
  font-size: 40px;
  font-weight: 500;
  color: #9E8C6C;
  letter-spacing: 8rpx;
  line-height: 1.4;
}
.brand-sub {
  font-size: 24rpx;
  color: #8A8A90;
  font-family: 'Courier New', monospace;
  letter-spacing: 8rpx;
  margin-top: 8rpx;
  text-transform: uppercase;
}
.btn-login {
  width: 590rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: rgba(235,235,229,0.08);
  color: #EBEBE5;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  margin-bottom: 32rpx;
}
.btn-guest {
  font-size: 32rpx;
  color: #8A8A90;
  margin-bottom: 64rpx;
}
.agreement {
  position: absolute;
  bottom: 96rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 24rpx;
  color: #8A8A90;
  line-height: 1.7;
}
.link { text-decoration: underline; }

/* 登录按钮区 */
.login-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

/* 头像昵称设置区 */
.profile-setup {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  width: 100%;
  margin-bottom: 64rpx;
}
.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}
.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(235,235,229,0.15);
  display: block;
  box-sizing: border-box;
}
.avatar-trigger {
  position: absolute;
  top: 0;
  left: 0;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: transparent;
  border: none;
  padding: 0;
  opacity: 0;
}
.avatar-trigger::after { border: none; }
.avatar-label {
  font-size: 24rpx;
  color: #8A8A90;
}
.input-nickname {
  width: 590rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background: rgba(235,235,229,0.06);
  border: 1rpx solid #3E4A58;
  color: #EBEBE5;
  font-size: 32rpx;
  text-align: center;
  box-sizing: border-box;
  padding: 0 24rpx;
}
.btn-start {
  width: 590rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: rgba(235,235,229,0.08);
  color: #EBEBE5;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}
