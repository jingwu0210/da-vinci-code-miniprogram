.login-page { background:#2C3A4A; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:0 60rpx; overflow-x:hidden; width:100vw; box-sizing:border-box; }

/* === 牌组展示：错落堆叠 === */
.hero { position:relative; width:340rpx; height:210rpx; margin-bottom:48rpx; }
.hero-card { position:absolute; }
.hero-tile { width:80rpx; height:112rpx; border-radius:6rpx; display:flex; flex-direction:column; align-items:center; justify-content:center; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.3); }
.hero-tile.black { background:#1E1E22; }
.hero-tile.white { background:#E8E4DC; }
.hero-num { font-family:'PingFang SC',sans-serif; font-weight:700; font-size:40rpx; line-height:1; color:#D8D4CC; }
.hero-tile.white .hero-num { color:#3A3834; }
.hero-line { width:36rpx; height:1rpx; margin-top:4rpx; background:rgba(255,255,255,0.15); }
.white-line { background:rgba(0,0,0,0.15); }

/* 4 张牌横向扇形展开 */
.c1 { top:56rpx; left:0; transform:rotate(-12deg); z-index:2; }
.c2 { top:0; left:76rpx; transform:rotate(6deg); z-index:1; }
.c3 { top:28rpx; left:148rpx; transform:rotate(-4deg); z-index:3; }
.c4 { top:72rpx; left:218rpx; transform:rotate(14deg); z-index:2; }

/* === 品牌 === */
.brand { text-align:center; margin-bottom:64rpx; }
.brand-title { font-size:42rpx; font-weight:500; color:#B8A282; letter-spacing:10rpx; line-height:1.5; }
.brand-sub { font-size:20rpx; color:#7A786E; font-family:'Courier New',monospace; letter-spacing:8rpx; margin-top:4rpx; }

/* === 按钮 === */
.actions { display:flex; flex-direction:column; align-items:center; width:100%; gap:20rpx; margin-bottom:48rpx; }
.btn { width:100%; height:96rpx; border-radius:8rpx; font-size:30rpx; display:flex; align-items:center; justify-content:center; border:none; }
.btn-wechat { background:rgba(235,235,229,0.1); color:#EBEBE5; }
.btn-guest { background:transparent; color:#8A8A90; font-size:26rpx; height:auto; padding:16rpx 0; }
.btn-start { background:rgba(235,235,229,0.1); color:#EBEBE5; width:100%; height:96rpx; border-radius:8rpx; font-size:30rpx; border:none; }

/* === 协议 === */
.agreement { position:absolute; bottom:80rpx; left:0; right:0; text-align:center; }
.agree-text { font-size:22rpx; color:#6A6A70; }
.agree-link { font-size:22rpx; color:#8A8A90; text-decoration:underline; }

/* === 头像昵称 === */
.profile-setup { display:flex; flex-direction:column; align-items:center; gap:24rpx; width:100%; margin-bottom:64rpx; }
.avatar-wrapper { position:relative; width:120rpx; height:120rpx; }
.profile-avatar { width:120rpx; height:120rpx; border-radius:50%; border:2rpx solid rgba(235,235,229,0.15); display:block; box-sizing:border-box; }
.avatar-trigger { position:absolute; inset:0; border-radius:50%; background:transparent; border:none; padding:0; opacity:0; }
.avatar-trigger::after { border:none; }
.input-nickname { width:100%; height:96rpx; border-radius:8rpx; background:rgba(235,235,229,0.06); border:1rpx solid #3E4A58; color:#EBEBE5; font-size:30rpx; text-align:center; box-sizing:border-box; padding:0 24rpx; }
