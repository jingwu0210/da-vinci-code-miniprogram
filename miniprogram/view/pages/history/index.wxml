<view class="page">
  <!-- 加载态 -->
  <view class="loading-ctn" wx:if="{{loading}}">
    <text class="loading-text">加载中…</text>
  </view>

  <!-- 空态 -->
  <view class="empty-ctn" wx:elif="{{empty}}">
    <text class="empty-emoji">📋</text>
    <text class="empty-text">暂无对局记录</text>
    <text class="empty-hint">完成一局对局后这里会出现记录</text>
  </view>

  <!-- 列表 -->
  <block wx:else>
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-num">{{stats.totalGames}}</text>
        <text class="stat-label">总场次</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.wins}}</text>
        <text class="stat-label">胜场</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">{{stats.winRate}}</text>
        <text class="stat-label">胜率</text>
      </view>
    </view>

    <view class="record-list">
      <view class="record-card {{item.myWin ? 'card-win' : 'card-lose'}}" wx:for="{{records}}" wx:key="*this">
        <view class="record-body">
          <view class="record-top">
            <view class="record-mode-row">
              <image class="record-mode-icon" src="/images/icons/{{item.mode === 'ai' ? 'bot-small' : 'users-small'}}.svg" />
              <text class="record-mode">{{item.modeLabel}}</text>
            </view>
            <text class="record-result {{item.myWin ? 'record-win' : 'record-lose'}}">{{item.myWin ? '胜' : '负'}}</text>
          </view>
          <view class="record-meta">
            <text class="record-date">{{item.dateStr}}</text>
            <text class="record-info">{{item.totalTurns}} 回合 · {{item.durStr}}</text>
          </view>
          <view class="record-players">
            <text wx:for="{{item.players}}" wx:key="openid" wx:for-item="p" class="record-player {{p.isWinner ? 'player-win' : ''}}">
              {{p.nickName}} · {{p.tilesRemaining}}张
            </text>
          </view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{hasMore}}">
      <text class="load-more-text">上拉加载更多</text>
    </view>
    <view class="load-more" wx:else>
      <text class="load-more-text">— 没有更多了 —</text>
    </view>
  </block>
</view>
