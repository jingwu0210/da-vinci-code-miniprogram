.page { min-height:100vh; background:var(--bg-page); padding:24rpx 32rpx calc(env(safe-area-inset-bottom, 0) + 24rpx); }

.loading-ctn, .empty-ctn { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; padding-top:200rpx; }
.loading-text { font-size:var(--fs-body); color:var(--text-secondary); }
.empty-emoji { font-size:72rpx; margin-bottom:16rpx; }
.empty-text { font-size:var(--fs-subtitle); color:var(--text-primary); margin-bottom:8rpx; }
.empty-hint { font-size:var(--fs-caption); color:var(--text-secondary); }

/* ── 统计卡片 ── */
.stats-card { display:flex; align-items:center; background:var(--bg-card); border-radius:24rpx; padding:32rpx 0; margin-bottom:24rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,0.08); }
.stat-item { flex:1; display:flex; flex-direction:column; align-items:center; }
.stat-num { font-size:var(--fs-subtitle); color:var(--text-primary); font-weight:700; }
.stat-label { font-size:var(--fs-caption); color:var(--text-secondary); margin-top:4rpx; }
.stat-divider { width:1rpx; height:48rpx; background:var(--divider); }

/* ── 记录卡片 ── */
.record-card {
  border-radius:24rpx; overflow:hidden;
  margin-bottom:16rpx; box-shadow:0 4rpx 16rpx rgba(0,0,0,0.08);
  background:var(--bg-card);
  border-left:10rpx solid transparent;
}
.card-win { border-left-color:#10B981; }
.card-lose { border-left-color:#EF4444; }

.record-body {
  padding:20rpx 24rpx;
}

.record-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:8rpx; }
.record-mode-row { display:flex; align-items:center; gap:8rpx; }
.record-mode-icon { width:36rpx; height:36rpx; flex-shrink:0; }
.record-mode { font-size:var(--fs-body); color:var(--text-primary); }
.record-result { font-size:var(--fs-body); font-weight:600; }
.record-win { color:#10B981; }
.record-lose { color:#EF4444; }

.record-meta { display:flex; justify-content:space-between; margin-bottom:8rpx; }
.record-date, .record-info { font-size:var(--fs-caption); color:var(--text-secondary); }

.record-players { display:flex; flex-wrap:wrap; gap:8rpx; }
.record-player { font-size:var(--fs-caption); color:var(--text-secondary); padding:4rpx 12rpx; border-radius:4rpx; }
.player-win { color:var(--gold); font-weight:500; }

.load-more { display:flex; justify-content:center; padding:24rpx 0; }
.load-more-text { font-size:var(--fs-caption); color:var(--text-secondary); }
