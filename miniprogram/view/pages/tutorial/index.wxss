.page { background:var(--bg-page); min-height:100vh; display:flex; flex-direction:column; }
.swiper { flex:1; height:100vh; }

.step-scroll { height:100%; padding:32rpx 32rpx calc(env(safe-area-inset-bottom, 0) + 120rpx); box-sizing:border-box; width:100%; overflow-x:hidden; }
.step-header { margin-bottom:24rpx; }
.step-num { font-size:22rpx; color:var(--text-secondary); display:block; margin-bottom:4rpx; }
.step-title { font-size:40rpx; color:var(--text-primary); font-weight:700; }
.step-body { margin-top:8rpx; width:100%; overflow-x:hidden; }
.step-desc { font-size:28rpx; color:var(--text-secondary); line-height:1.8; display:block; margin-bottom:16rpx; word-break:break-all; }

/* === Example box === */
.example-box { background:var(--bg-card); border:1rpx solid var(--divider); border-radius:24rpx; padding:24rpx; margin:16rpx 0; box-shadow:0 2rpx 8rpx rgba(0,0,0,0.06); }
.example-label { font-size:24rpx; color:var(--gold); font-weight:600; display:block; margin-bottom:12rpx; }
.example-caption { font-size:22rpx; color:var(--text-secondary); display:block; margin-top:12rpx; line-height:1.6; }

/* === Rule list === */
.rule-list { display:flex; flex-direction:column; gap:8rpx; }
.rule-item { font-size:26rpx; color:var(--text-secondary); line-height:1.6; }

/* === Demo tiles === */
.tile-row { display:flex; gap:10rpx; flex-wrap:wrap; }
.demo-tile { width:64rpx; height:100rpx; border-radius:4rpx; display:flex; align-items:center; justify-content:center; font-size:26rpx; font-weight:700; font-family:'Courier New',monospace; }
.demo-tile.black { background:linear-gradient(135deg,#2A2A30,#1A1A1E); color:#F0F0E8; border:0.5rpx solid rgba(255,255,255,0.1); }
.demo-tile.white { background:linear-gradient(135deg,#F5F5EE,#DEDED6); color:#1A1A1E; border:0.5rpx solid rgba(0,0,0,0.1); }
.demo-tile.joker { color:#C9A84C; font-size:32rpx; }
.demo-tile.back { color:#5A5A60; font-size:32rpx; }
.demo-tile.back.white { color:#A0A098; }

